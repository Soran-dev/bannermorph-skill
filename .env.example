# BannerMorph skill 配置模板
# 复制为 .env 并填写,或使用 `node scripts/config.js '{"api_key":"sk-xxx"}'` 自动生成

# 你的 ideaLAB API key (必填)
IDEALAB_API_KEY=

# 以下两项可选 — 想换 endpoint / 模型时填,否则用默认
# BANNER_SKILL_BASE_URL=https://idealab.alibaba-inc.com/api/openai/v1
# BANNER_SKILL_MODEL=gemini-3.1-flash-image-preview
